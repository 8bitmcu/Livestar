<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Stars section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stars_section"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/density_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <SeekBar
            android:id="@+id/density_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/size_min_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp" />

        <SeekBar
            android:id="@+id/size_min_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/size_max_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp" />

        <SeekBar
            android:id="@+id/size_max_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/brightness_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp" />

        <SeekBar
            android:id="@+id/brightness_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <TextView
            android:id="@+id/twinkle_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp" />

        <SeekBar
            android:id="@+id/twinkle_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <!-- Rendering section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rendering_section"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/fps_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <SeekBar
            android:id="@+id/fps_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="1"
            android:max="60" />

        <CheckBox
            android:id="@+id/battery_saving_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/battery_saving" />

        <Button
            android:id="@+id/apply_wallpaper_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="@string/apply_wallpaper_button" />

    </LinearLayout>

</ScrollView>
